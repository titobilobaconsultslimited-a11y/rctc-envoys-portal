# ============================================================
# Vercel Environment Variables
# Copy this file to .env.local for local development.
# Set these in the Vercel dashboard for production.
# ============================================================

# Supabase project URL — safe to use in both server and client
SUPABASE_URL=https://your-project.supabase.co

# Supabase service role key — SERVER-SIDE ONLY, never expose in browser
# Found at: Supabase Dashboard → Project Settings → API → service_role key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Supabase anon/public key — used client-side for Supabase Auth sign-in only
# Found at: Supabase Dashboard → Project Settings → API → anon/public key
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Admin credentials — stored server-side only
# Create a user in Supabase Auth (Dashboard → Authentication → Users)
# with these credentials, then paste the email here for reference.
# The actual authentication is delegated to Supabase Auth — no password
# is stored in these env vars.
# (These are ONLY used if you chose the custom-token admin approach.)
# ADMIN_USERNAME=admin@yourschool.org
# ADMIN_PASSWORD=your-admin-password
# ADMIN_SECRET_KEY=a-long-random-secret-for-signing-tokens
